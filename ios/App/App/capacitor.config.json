{
	"appId": "app.lifetodo",
	"appName": "Life To Do",
	"webDir": "out",
	"server": {
		"cleartext": false
	},
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#0A0A0F",
			"showSpinner": false,
			"launchFadeOutDuration": 300
		},
		"StatusBar": {
			"style": "dark",
			"backgroundColor": "#0A0A0F"
		},
		"Keyboard": {
			"resize": "body",
			"style": "dark",
			"resizeOnFullScreen": true
		},
		"LocalNotifications": {
			"smallIcon": "ic_notification",
			"iconColor": "#6366F1"
		}
	},
	"ios": {
		"scheme": "Life To Do",
		"contentInset": "automatic"
	},
	"android": {},
	"packageClassList": [
		"AppPlugin",
		"FilesystemPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"LocalNotificationsPlugin",
		"PushNotificationsPlugin",
		"SharePlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin",
		"PurchasesPlugin",
		"NativeBiometric"
	]
}
